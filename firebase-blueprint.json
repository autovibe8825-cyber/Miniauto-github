{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A scale model car product in the store database.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "scale": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "stock": { "type": "integer" },
        "category": { "type": "string" },
        "year": { "type": "integer" }
      },
      "required": ["id", "name", "brand", "scale", "price", "imageUrl", "stock", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "An order placed by a customer.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "userAddress": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending_payment", "paid", "preparing", "shipping", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["momo", "zalopay", "shopeepay", "bank_transfer"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "userPhone", "userAddress", "items", "totalAmount", "status", "paymentMethod", "paymentStatus", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile containing PII and role info.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "role", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store items collection."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders placed by clients, containing shipping details and status."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Users profile data containing PII, requiring owner or admin authorization."
    }
  }
}
